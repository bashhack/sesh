#!/usr/bin/env bash
# Pre-commit hook for Go code quality checks
# This runs before every commit to ensure code quality standards

set -e
set -o pipefail  # Make pipelines fail if any command fails

echo "🔍 Running pre-commit checks..."

# Check if goimports is installed
if ! command -v goimports >/dev/null 2>&1; then
    echo "📦 Installing goimports..."
    go install golang.org/x/tools/cmd/goimports@latest
fi

# Check if golangci-lint is installed with correct version
REQUIRED_GOLANGCI_VERSION="2.6.2"
INSTALL_GOLANGCI=false
if ! command -v golangci-lint >/dev/null 2>&1; then
    echo "golangci-lint not found"
    INSTALL_GOLANGCI=true
else
    CURRENT_VERSION=$(golangci-lint --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)
    if [ "$CURRENT_VERSION" != "$REQUIRED_GOLANGCI_VERSION" ]; then
        echo "golangci-lint version $CURRENT_VERSION found, but v$REQUIRED_GOLANGCI_VERSION required"
        INSTALL_GOLANGCI=true
    fi
fi
if [ "$INSTALL_GOLANGCI" = "true" ]; then
    echo "📦 Installing golangci-lint v$REQUIRED_GOLANGCI_VERSION..."
    curl -sSfL https://raw.githubusercontent.com/golangci/golangci-lint/HEAD/install.sh | sh -s -- -b $(go env GOPATH)/bin v$REQUIRED_GOLANGCI_VERSION
fi

# Get list of staged Go files
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' | grep -v 'vendor/' || true)

if [ -z "$STAGED_GO_FILES" ]; then
    echo "✅ No Go files to check"
    exit 0
fi

echo "📝 Checking Go files:"
echo "$STAGED_GO_FILES" | sed 's/^/  - /'

# Get unique package directories from staged files (exclude scripts/ - standalone utilities)
STAGED_PACKAGES=$(echo "$STAGED_GO_FILES" | grep -v '^scripts/' | xargs -n1 dirname | sort -u | sed 's|^|./|')
echo ""
echo "📦 Packages to check:"
echo "$STAGED_PACKAGES" | sed 's/^/  - /'

# Check formatting
echo ""
echo "🎨 Checking code formatting..."
UNFORMATTED=$(goimports -l -local github.com/bashhack/sesh $STAGED_GO_FILES)
if [ -n "$UNFORMATTED" ]; then
    echo "❌ The following files need formatting:"
    echo "$UNFORMATTED" | sed 's/^/  - /'
    echo ""
    echo "Run: make format"
    echo "Then: git add <files>"
    exit 1
fi

# Quick compile check on entire codebase (catches cross-package breakage)
echo "🔨 Checking compilation..."
if ! go build ./... ; then
    echo "❌ Build failed"
    echo "Fix the errors above and try again"
    exit 1
fi

# Run go vet on staged packages only
echo "🔬 Running go vet..."
if ! echo "$STAGED_PACKAGES" | xargs go vet ; then
    echo "❌ go vet failed"
    echo "Fix the errors above and try again"
    exit 1
fi

# Run golangci-lint on staged packages only
echo "🔍 Running golangci-lint..."
if ! echo "$STAGED_PACKAGES" | xargs golangci-lint run ; then
    echo "❌ golangci-lint failed"
    echo "Fix the errors above and try again"
    exit 1
fi

echo ""
echo "✅ All pre-commit checks passed!"
